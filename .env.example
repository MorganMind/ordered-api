# Django
DJANGO_SETTINGS_MODULE=ordered_api.settings
DEBUG=True
SECRET_KEY=change-me

# Production on a VPS (DEBUG=False): set all of the following.
# ALLOWED_HOSTS=api.yourdomain.com,your.droplet.ip
# CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://operator.yourdomain.com,https://app.yourdomain.com
# Each entry MUST include the scheme (https:// or http://). Bare hostnames like api.example.com will fail (corsheaders.E013).
# List origins of *browser apps* that call this API — usually your frontend, not the API hostname alone.
# Optional: behind nginx only, if you see redirect loops set SECURE_SSL_REDIRECT=False
# SECURE_SSL_REDIRECT=True

# Container / process (Docker, systemd, Procfile-style)
# PORT=8000
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120

# One database for Django ORM + same Supabase Postgres as migrations.sql
# Supabase → Project Settings → Database → Connection string → URI
# Prefer "Transaction pooler" (port 6543) for serverless / Cloud Run.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:YOUR_PASSWORD@aws-0-....pooler.supabase.com:6543/postgres?sslmode=require

# Alternative to DATABASE_URL (same result):
# SUPABASE_DB_HOST=aws-0-....pooler.supabase.com
# SUPABASE_DB_PASSWORD=your_password
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_PORT=6543

# Supabase API (REST / auth client — unchanged)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Optional: UUID of a tenants.Tenant row when Supabase JWT has no tenant_id (local dev only).
# Prefer setting tenant_id (or tenant: { id }) on auth.users raw_app_meta_data instead.
# AUTH_ME_FALLBACK_TENANT_ID=
